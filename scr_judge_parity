/// scr_judge_parity

if (!instance_exists(obj_player)) {
    show_debug_message("ERROR: obj_player does not exist when scr_judge_parity is called!");
    return;
}

var diff = abs(obj_player.player_guess_percent - obj_player.true_parry_percent);

// ... rest of your judgment logic
// PERFECT PARry (±3%)
if (diff <= 3) {
    with (obj_player.enemy_instance) {
        instance_destroy();
    }
    obj_player.streak += 1;
    obj_player.streak_time_bonus += 2;
    obj_player.game_state = "playing";

    // Currency reward based on difficulty band (easy/medium/hard)
    var band = obj_player.current_difficulty_band;
    switch (band) {
        case 0: obj_player.currency += 100; break;  // easy
        case 1: obj_player.currency += 300; break;  // medium
        case 2: obj_player.currency += 500; break;  // hard
    }
}

// NEAR PARry (±4–10%)
else if (diff <= 10) {
    var hp_loss = 15;
    if (obj_player.moderate_near_loss) {
        hp_loss = 10;  // safer parry (item 3)
    }
    obj_player.hp -= hp_loss;

    obj_player.streak = max(0, obj_player.streak);
    obj_player.game_state = "playing";
}

